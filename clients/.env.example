########################################
# Google Vertex AI (Gemini / ADC)
########################################

# Vertex AI ADC (Application Default Credentials)
# GOOGLE_CLOUD_PROJECT=PROJECT_ID
# GOOGLE_CLOUD_LOCATION=PROJECT_LOCATION
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

########################################
# Google Vertex AI (Express)
########################################
GOOGLE_GENAI_API_KEY=your-google-genai-api-key
VERTEX_AI=true

########################################
# Google Gemini (BeeAI Framework)
########################################
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-3-pro-preview

########################################
# Agents
########################################
POLICY_AGENT_PORT=9999
RESEARCH_AGENT_PORT=9998
FIND_PROVIDERS_AGENT_PORT=9997

########################################
# dotenv runtime behavior
########################################
DOTENV_CONFIG_QUIET=true

